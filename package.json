{
  "name": "arbor",
  "version": "0.1.0",
  "description": "AI-powered SDK documentation generator using tree-sitter parsing and Claude API enrichment",
  "type": "module",
  "main": "dist/core/engine.js",
  "bin": {
    "arbor": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "postinstall": "npm rebuild tree-sitter || true"
  },
  "keywords": [
    "documentation",
    "tree-sitter",
    "ai",
    "claude",
    "sdk"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "glob": "^11.0.1",
    "handlebars": "^4.7.8",
    "ora": "^8.2.0",
    "simple-git": "^3.27.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-kotlin": "^0.3.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
